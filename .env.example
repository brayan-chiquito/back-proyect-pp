# Copiar a .env y completar (ver docs/task/tarea2.md).

# API Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Modelo para respuestas del bot en WhatsApp
AI_MODEL=claude-haiku-4-5-20251001

# Puerto HTTP del bridge Node (Baileys + express)
BRIDGE_PORT=3000

# URL base del bridge (httpx desde backend hacia /send)
BRIDGE_URL=http://localhost:3000

# URL base del backend FastAPI (httpx desde bridge)
BACKEND_URL=http://localhost:8000

# Secreto compartido: el backend valida peticiones del bridge
BRIDGE_SECRET=

# Excel online de catálogo (URL directa al .xlsx)
EXCEL_URL=

# TTL de caché en memoria del catálogo (minutos)
EXCEL_CACHE_MINUTES=30

# Números WhatsApp de operadores por tenant (escalamiento)
OPERATOR_PASTELERIA=
OPERATOR_PIJAMAS=
OPERATOR_COMIDA=

# Inactividad de sesión de conversación (minutos)
SESSION_TIMEOUT_MINUTES=30

# Bloqueo por abuso tras límites en guard.py (minutos)
ABUSE_BLOCK_MINUTES=60

# Umbral de precio que dispara escalamiento (moneda local, entero)
ESCALATION_PRICE_LIMIT=500000

# Supabase (producción; vacío en dev con JSON en disco)
SUPABASE_URL=
SUPABASE_KEY=
